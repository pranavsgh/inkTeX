# Backend server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Model weights / paths
MATH_MODEL_WEIGHTS_PATH=weights/math_model.pt
LAYOUT_MODEL_WEIGHTS_PATH=weights/yolov8_layout.pt
TEXT_OCR_MODEL_NAME=microsoft/trocr-base-handwritten

# Inference device: cpu | cuda | mps
DEVICE=cpu

# PDF compilation
PDFLATEX_BIN=pdflatex
PDF_COMPILE_TIMEOUT_SECONDS=30

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Third-party API keys (placeholders — do not commit real keys)
WANDB_API_KEY=your-wandb-api-key-here
HUGGINGFACE_TOKEN=your-huggingface-token-here
